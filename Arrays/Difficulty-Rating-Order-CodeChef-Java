/*
Problem: Difficulty Rating Order
Platform: CodeChef
Pattern: Array Traversal + Non-Decreasing Check

Approach:
- Traverse the array and compare adjacent elements.
- If any element is greater than the next element,
  then the sequence is not non-decreasing.
- Otherwise, the sequence is valid.

Time Complexity: O(N)
Space Complexity: O(N)
*/

import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        for (int t = 0; t < T; t++) {

            int N = sc.nextInt();
            int[] d = new int[N];

            for (int i = 0; i < N; i++) {
                d[i] = sc.nextInt();
            }

            int count = 0;

            for (int i = 0; i < N - 1; i++) {
                if (d[i] > d[i + 1]) {
                    count++;
                }
            }

            if (count == 0) {
                System.out.println("Yes");
            } else {
                System.out.println("No");
            }
        }

        sc.close();
    }
}
